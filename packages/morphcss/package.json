{
  "name": "@morph-css/kit",
  "version": "0.4.4",
  "description": "Zero-runtime atomic CSS-in-JS for Vite and Next.js",
  "author": "Devansh Gupta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeReb00t/morphcss.git",
    "directory": "packages/morphcss"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": {
      "types": "./dist/css-import.d.ts",
      "import": "./dist/css-import.js",
      "require": "./dist/css-import.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./loader": "./dist/loader.cjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "@morph-css/node": "^0.4.3",
    "csstype": "^3.1.3"
  },
  "peerDependencies": {
    "next": "^14.0.0",
    "vite": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.0"
  }
}
