{
  "name": "@morph-css/node",
  "version": "0.4.6",
  "author": "Devansh Gupta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CodeReb00t/morphcss.git",
    "directory": "crates/morphcss_node"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "morphcss-node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0-alpha.52"
  },
  "optionalDependencies": {
    "@morph-css/node-linux-x64-gnu": "0.4.6",
    "@morph-css/node-darwin-arm64": "0.4.6",
    "@morph-css/node-darwin-x64": "0.4.6",
    "@morph-css/node-win32-x64-msvc": "0.4.6"
  }
}
