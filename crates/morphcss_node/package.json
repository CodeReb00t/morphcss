{
  "name": "@morph-css/node",
  "version": "0.4.6",
  "author": "Devansh Gupta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CodeReb00t/morphcss.git",
    "directory": "crates/morphcss_node"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "morphcss-node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.3"
  }
}
